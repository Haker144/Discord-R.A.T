# Example environment configuration for Discord RAT
# Copy this file to .env and replace placeholder values with actual credentials.

DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE
RAT_AUTH_TOKEN=YOUR_RAT_AUTH_TOKEN_HERE
RAT_LISTEN_PORT=9091
RAT_DB_PATH=log.db
RAT_ENDPOINT=http://localhost:9091/execute
COMMAND_PREFIX=! # Command prefix for bot commands
PERSISTENCE=off # Set to "on" to enable startup persistence
USE_NGROK=false # Set to "true" to enable Ngrok tunneling